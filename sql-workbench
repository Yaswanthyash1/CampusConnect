DROP USER IF EXISTS 'clubuser'@'localhost';

DROP DATABASE IF EXISTS clubdb;
DROP DATABASE IF EXISTS userdb;
DROP DATABASE IF EXISTS requestdb;

CREATE DATABASE clubdb;
CREATE DATABASE userdb;
CREATE DATABASE requestdb;

CREATE USER 'clubuser'@'localhost' IDENTIFIED BY 'clubpass';
GRANT ALL PRIVILEGES ON clubdb.* TO 'clubuser'@'localhost';
GRANT ALL PRIVILEGES ON userdb.* TO 'clubuser'@'localhost';
GRANT ALL PRIVILEGES ON requestdb.* TO 'clubuser'@'localhost';
FLUSH PRIVILEGES;

SHOW DATABASES;
SELECT user, host FROM mysql.user;


USE userdb;
SHOW TABLES;

-- User table
CREATE TABLE user (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    srn VARCHAR(255) NOT NULL UNIQUE,
    username VARCHAR(255) UNIQUE,
    name VARCHAR(255),
    email VARCHAR(255),
    password VARCHAR(255),
    role VARCHAR(255),
    domain VARCHAR(255),
    sem INT,
    dept VARCHAR(255),
    phoneno VARCHAR(255),
    gender VARCHAR(255),
    club VARCHAR(255)
);

USE clubdb;
SHOW TABLES;

-- Club table
CREATE TABLE club (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    clubName VARCHAR(255),
    description VARCHAR(255),
    faculty_id VARCHAR(255),
    clubType VARCHAR(255),
    head_srn VARCHAR(255),
    name VARCHAR(255),
    phoneno VARCHAR(255),
    dept VARCHAR(255),
    gender VARCHAR(255),
    sem INT,
    password VARCHAR(255)
);


USE requestdb;
SHOW TABLES;

-- Request table
CREATE TABLE request (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    member_id VARCHAR(255),
    type VARCHAR(255),
    description VARCHAR(255),
    file_path VARCHAR(255),
    timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    status VARCHAR(255),
    clubName VARCHAR(255),
    is_completed BIT(1)
);

