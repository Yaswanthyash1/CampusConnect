CREATE DATABASE clubdb;

CREATE USER 'clubuser'@'localhost' IDENTIFIED BY 'clubpass';
GRANT ALL PRIVILEGES ON clubdb.* TO 'clubuser'@'localhost';
FLUSH PRIVILEGES;

SHOW DATABASES;
SELECT user, host FROM mysql.user;

USE clubdb;
SHOW TABLES;

SELECT * FROM USER;
CREATE TABLE club (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    club_name VARCHAR(255),
    description VARCHAR(255),
    faculty_id VARCHAR(255),
    club_type VARCHAR(255),
    head_srn VARCHAR(255),
    name VARCHAR(255),
    sem INT,
    dept VARCHAR(255),
    phoneno VARCHAR(255),
    gender VARCHAR(255)
);

DROP TABLE USER;
CREATE TABLE user (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(255) UNIQUE,
    password VARCHAR(255),
    role VARCHAR(255)
);

CREATE TABLE member (
    srn VARCHAR(255) PRIMARY KEY,
    name VARCHAR(255),
    email VARCHAR(255),
    domain VARCHAR(255),
    sem INT,
    dept VARCHAR(255),
    phoneno VARCHAR(255),
    gender VARCHAR(255),
    password VARCHAR(255)
);

CREATE TABLE event (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    clubName VARCHAR(255),
    eventName VARCHAR(255),
    description VARCHAR(255),
    location VARCHAR(255),
    type VARCHAR(255),
    timestamp DATETIME,
    budget DOUBLE,
    registrationLink VARCHAR(255),
    banner BLOB
);

CREATE TABLE your_table_name (
    id BIGINT NOT NULL AUTO_INCREMENT PRIMARY KEY,
    member_id VARCHAR(255),
    type VARCHAR(255),
    description VARCHAR(255),
    file_path VARCHAR(255),
    timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    status VARCHAR(255),
    club_name VARCHAR(255)
);

ALTER TABLE member ADD COLUMN club VARCHAR(255) DEFAULT NULL;


CREATE TABLE project (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    clubname VARCHAR(255) NOT NULL,
    projectname VARCHAR(255) NOT NULL,
    description TEXT,
    category VARCHAR(100),
    priority VARCHAR(50),
    startdate DATE,
    enddate DATE,
    budget DECIMAL(10,2) DEFAULT 0.00,
    teamsize INT DEFAULT 1,
    technologies TEXT,
    objectives TEXT NOT NULL,
    deliverables TEXT NOT NULL,
    mentor VARCHAR(255),
    status VARCHAR(50) DEFAULT 'Planning',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
    attachments TEXT,

    -- Indexes for better performance
    INDEX idx_clubname (clubname),
    INDEX idx_status (status),
    INDEX idx_category (category),
    INDEX idx_priority (priority),
    INDEX idx_startdate (startdate),
    INDEX idx_created_at (created_at)
);



